<!DOCTYPE html>
<html>
<head>
<meta charset="UTF-8">
<title>AI Broker PRO</title>
<script src="https://s3.tradingview.com/tv.js"></script>

<style>
body{
  margin:0;
  font-family:Arial;
  background:#0b1220;
  color:white;
}

header{
  background:#0f172a;
  padding:15px;
  display:flex;
  justify-content:space-between;
  align-items:center;
  font-size:18px;
}

.container{
  display:flex;
  height:calc(100vh - 60px);
}

#chart{
  flex:3;
}

.panel{
  flex:1;
  background:#111827;
  padding:15px;
  display:flex;
  flex-direction:column;
  gap:8px;
  overflow:auto;
}

input,select,button{
  padding:7px;
  border:none;
  border-radius:4px;
}

button{
  cursor:pointer;
  font-weight:bold;
}

.buy{background:#16a34a;color:white;}
.sell{background:#dc2626;color:white;}
.closebtn{background:#374151;color:white;font-size:12px;padding:3px 6px;}

table{
  width:100%;
  font-size:12px;
  border-collapse:collapse;
}

th,td{
  padding:4px;
  border-bottom:1px solid #1f2937;
  text-align:center;
}

.stats{
  background:#0b1220;
  padding:10px;
  margin-top:10px;
  font-size:13px;
}
</style>
</head>

<body>

<header>
  <div>AI Broker PRO DEMO</div>
  <div>Balance: $<span id="balance">10000</span></div>
</header>

<div class="container">

<div id="chart"></div>

<div class="panel">

<select id="asset" onchange="changeAsset()">
<option>BTCUSDT</option>
<option>ETHUSDT</option>
<option>BNBUSDT</option>
<option>XRPUSDT</option>
<option>SOLUSDT</option>
<option>ADAUSDT</option>
<option>DOGEUSDT</option>
<option>DOTUSDT</option>
<option>MATICUSDT</option>
<option>AVAXUSDT</option>
<option>EURUSD</option>
<option>GBPUSD</option>
<option>USDJPY</option>
<option>AUDUSD</option>
<option>USDCAD</option>
<option>XAUUSD</option>
<option>XAGUSD</option>
<option>USOIL</option>
<option>UKOIL</option>
<option>AAPL</option>
<option>TSLA</option>
<option>AMZN</option>
<option>MSFT</option>
<option>NVDA</option>
<option>META</option>
<option>GOOGL</option>
<option>NFLX</option>
<option>INTC</option>
<option>AMD</option>
<option>BABA</option>
</select>

<select id="orderType">
<option value="market">Market</option>
</select>

<input id="volume" type="number" value="100" placeholder="Volume $">

<select id="leverage">
<option value="50">1:50</option>
<option value="100">1:100</option>
<option value="200">1:200</option>
<option value="500">1:500</option>
</select>

<input id="sl" type="number" placeholder="Stop Loss price">
<input id="tp" type="number" placeholder="Take Profit price">

<button class="buy" onclick="openTrade('buy')">BUY</button>
<button class="sell" onclick="openTrade('sell')">SELL</button>

<h3>Open Positions</h3>
<table>
<thead>
<tr>
<th>Asset</th>
<th>Type</th>
<th>Volume</th>
<th>Entry</th>
<th>PnL</th>
<th>Action</th>
</tr>
</thead>
<tbody id="positionsTable"></tbody>
</table>

<div class="stats">
Equity: $<span id="equity">10000</span><br>
Margin: $<span id="margin">0</span><br>
Free Margin: $<span id="free">10000</span><br>
Floating PnL: $<span id="pnl">0</span><br>
Margin Level: <span id="ml">0</span>%<br>
</div>

</div>
</div>

<script>

let currentAsset="BTCUSDT";
let currentPrice=0;
let ws;

let balance=10000;
let equity=10000;
let usedMargin=0;
let freeMargin=10000;
let marginLevel=0;
let totalPnL=0;
let stopOutPercent=50;

let positions=[];

function loadChart(symbol){
document.getElementById("chart").innerHTML="";
new TradingView.widget({
symbol:symbol,
interval:"15",
container_id:"chart",
theme:"dark",
style:"1",
locale:"en",
toolbar_bg:"#111827",
width:"100%",
height:"100%"
});
}

loadChart(currentAsset);

function changeAsset(){
currentAsset=document.getElementById("asset").value;
loadChart(currentAsset);
connectPrice(currentAsset);
}

function connectPrice(symbol){

if(ws) ws.close();

if(symbol.includes("USDT")){
ws=new WebSocket("wss://stream.binance.com:9443/ws/"+symbol.toLowerCase()+"@trade");
ws.onmessage=function(e){
let data=JSON.parse(e.data);
currentPrice=parseFloat(data.p);
updatePositions();
};
}else{
currentPrice=100;
setInterval(()=>{
currentPrice+= (Math.random()-0.5);
updatePositions();
},1000);
}
}

connectPrice(currentAsset);

function openTrade(type){

let volume=parseFloat(document.getElementById("volume").value);
let leverage=parseFloat(document.getElementById("leverage").value);
let sl=parseFloat(document.getElementById("sl").value)||null;
let tp=parseFloat(document.getElementById("tp").value)||null;

let margin=volume/leverage;

if(margin>freeMargin){
alert("Not enough margin");
return;
}

positions.push({
id:Date.now(),
asset:currentAsset,
type:type,
volume:volume,
leverage:leverage,
entry:currentPrice,
sl:sl,
tp:tp,
margin:margin,
pnl:0
});

usedMargin+=margin;
updatePositions();
}

function closePosition(id){
let pos=positions.find(p=>p.id===id);
balance+=pos.pnl;
usedMargin-=pos.margin;
positions=positions.filter(p=>p.id!==id);
updatePositions();
}

function updatePositions(){

totalPnL=0;

positions.forEach(pos=>{

if(pos.type==="buy"){
pos.pnl=(currentPrice-pos.entry)*(pos.volume/currentPrice);
}else{
pos.pnl=(pos.entry-currentPrice)*(pos.volume/currentPrice);
}

if(pos.sl && ((pos.type==="buy" && currentPrice<=pos.sl) ||
(pos.type==="sell" && currentPrice>=pos.sl))){
closePosition(pos.id);
}

if(pos.tp && ((pos.type==="buy" && currentPrice>=pos.tp) ||
(pos.type==="sell" && currentPrice<=pos.tp))){
closePosition(pos.id);
}

totalPnL+=pos.pnl;
});

equity=balance+totalPnL;
freeMargin=equity-usedMargin;
marginLevel=usedMargin>0?(equity/usedMargin)*100:0;

if(marginLevel<stopOutPercent && positions.length>0){
positions.forEach(p=>closePosition(p.id));
alert("STOP OUT");
}

updateUI();
renderPositions();
}

function renderPositions(){
let table=document.getElementById("positionsTable");
table.innerHTML="";

positions.forEach(pos=>{
let row=`
<tr>
<td>${pos.asset}</td>
<td>${pos.type}</td>
<td>${pos.volume}</td>
<td>${pos.entry.toFixed(2)}</td>
<td style="color:${pos.pnl>=0?'#16a34a':'#dc2626'}">${pos.pnl.toFixed(2)}</td>
<td><button class="closebtn" onclick="closePosition(${pos.id})">X</button></td>
</tr>
`;
table.innerHTML+=row;
});
}

function updateUI(){
document.getElementById("balance").innerText=balance.toFixed(2);
document.getElementById("equity").innerText=equity.toFixed(2);
document.getElementById("margin").innerText=usedMargin.toFixed(2);
document.getElementById("free").innerText=freeMargin.toFixed(2);
document.getElementById("pnl").innerText=totalPnL.toFixed(2);
document.getElementById("ml").innerText=marginLevel.toFixed(2);
}

</script>

</body>
</html>
